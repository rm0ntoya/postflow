# Exemplo de variáveis de ambiente necessárias para rodar em produção
# Substitua os valores reais no painel do Discloud

# URI de conexão com MongoDB (ex: mongodb+srv://user:pass@cluster.mongodb.net/dbname)
MONGODB_URI=

# Chave AES-256-GCM hex (32 bytes -> 64 hex chars). Gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# Secret usado para assinar JWTs
JWT_SECRET=

# Secret usado para o endpoint de seed de admin (opcional)
ADMIN_SEED_SECRET=

# URL pública do site (ex: https://seu-app.discloud.app)
NEXT_PUBLIC_BASE_URL=https://postify.discloud.app

# Porta: o Discloud define `PORT` automaticamente; não é necessário setar aqui.
# NODE_ENV=production (opcional)
